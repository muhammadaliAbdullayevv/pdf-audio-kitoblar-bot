# =========================
# Required Core Settings
# =========================
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
BOT_DISPLAY_NAME=Pdf va audio kitoblar
BOT_PUBLIC_USERNAME=@pdf_audio_kitoblar_bot
TELEGRAM_OWNER_ID=123456789

DB_NAME=smartaitoolsbot
DB_USER=postgres
DB_PASS=replace_with_db_password
DB_HOST=127.0.0.1
DB_PORT=5432
# Optional single-URL form used by Alembic tooling.
DATABASE_URL=

# Where request/upload approval notifications go.
# If omitted, bot falls back to OWNER_ID.
REQUEST_CHAT_ID=123456789

# =========================
# Legacy Compatibility
# =========================
# Runtime auth is owner-only. Keep empty unless you need legacy scripts.
TELEGRAM_ADMIN_ID=

# =========================
# Telegram Local Bot API (Optional)
# =========================
TELEGRAM_BOT_API_BASE_URL=
TELEGRAM_BOT_API_BASE_FILE_URL=
TELEGRAM_BOT_API_LOCAL_MODE=0
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Required group/channel gate for bot use.
# Use the actual Telegram chat ID (-100...) or public @username for the check target.
# If you need a private invite link button, set BOOK_JOIN_TARGET_URL separately.
BOOK_JOIN_TARGET_ID=
BOOK_JOIN_TARGET_HANDLE=
BOOK_JOIN_TARGET_URL=

# Hidden private channel used to mint fresh file_ids for books.
# If empty, the bot falls back to the first existing book/upload channel env value.
BOOK_STORAGE_CHANNEL_ID=

# =========================
# Audio / Video Upload Channels
# =========================
AUDIO_UPLOAD_CHANNEL_IDS=
AUDIO_UPLOAD_CHANNEL_ID=
VIDEO_UPLOAD_CHANNEL_IDS=
VIDEO_UPLOAD_CHANNEL_ID=

# =========================
# Elasticsearch (Optional)
# =========================
ES_URL=
ES_USER=
ES_PASS=
ES_CA_CERT=
ES_HEALTH_CACHE_TTL_SEC=15

# =========================
# Redis (Optional)
# =========================
REDIS_URL=

# =========================
# Runtime / Concurrency
# =========================
# General async task workers (recommended: 50-100, default: 100)
THREAD_POOL_WORKERS=100
# Heavy operation workers for PDF/TTS/OCR processing (recommended: 10-20, default: 20)
HEAVY_THREAD_POOL_WORKERS=20
# Upload worker threads (recommended: 3-10, default: 5) - increase for high-concurrency scenarios
UPLOAD_LOCAL_WORKERS=5
# Database pool connections (recommended: 10-100, default: 100)
DB_POOL_MIN=10
DB_POOL_MAX=100
DB_RETRY_ATTEMPTS=2
DB_RETRY_BASE_DELAY_SEC=0.20
# Schema bootstrap mode:
# - auto: skip heavy startup DDL when core tables already exist (recommended)
# - always: run legacy runtime CREATE/ALTER bootstrap every startup
# - never: require migrations / pre-created schema
DB_RUNTIME_SCHEMA_MODE=auto
BOT_STARTUP_MAX_RETRIES=0
BOT_INSTANCE_LOCK_FILE=/tmp/smartaitoolsbot.instance.lock

# =========================
# Dashboard (Local Web UI)
# =========================
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8091
DASHBOARD_LOG_LEVEL=INFO

# =========================
# Upload / Index Tuning
# =========================
UPLOAD_AUTO_DOWNLOAD_LOCAL=1
UPLOAD_LOCAL_DIR=downloads/localbooks
UPLOAD_LOCAL_WORKER_COUNT=3
UPLOAD_LOCAL_DOWNLOAD_RETRIES=6
UPLOAD_LOCAL_RETRY_BASE_DELAY_SEC=2
UPLOAD_LOCAL_RETRY_MIN_DELAY_SEC=10
UPLOAD_LOCAL_WORKER_POLL_SECONDS=1
UPLOAD_LOCAL_JOB_COOLDOWN_SECONDS=0.1
UPLOAD_LOCAL_JOB_STALE_AFTER_SECONDS=3600
UPLOAD_LOCAL_GET_FILE_READ_TIMEOUT_SEC=300
UPLOAD_LOCAL_DOWNLOAD_READ_TIMEOUT_SEC=600
UPLOAD_LOCAL_CONNECT_TIMEOUT_SEC=45
UPLOAD_LOCAL_POOL_TIMEOUT_SEC=45
# Optional shared JPEG/PNG logo used as the thumbnail for uploaded books.
# If set, point it to a local file such as assets/book_thumbnail.png.
BOOK_THUMBNAIL_PATH=
# Watermark text used for PDF books before they are reuploaded to the storage channel.
# Defaults to the fixed branded string "Pdf va audio kitoblar" if left empty.
BOOK_WATERMARK_TEXT=
UPLOAD_LOCAL_WATERMARK_PDF=1
UPLOAD_ES_BULK_SIZE=100
UPLOAD_ES_BULK_IDLE_TIMEOUT_SEC=10
UPLOAD_NO_STATUS_EDITS=0
UPLOAD_SKIP_NAME_DUP_CHECK=0

# =========================
# Coins / Leaderboard
# =========================
COIN_SEARCH=1
COIN_DOWNLOAD=1
COIN_REACTION=1
COIN_FAVORITE=1
COIN_REFERRAL=15
TOP_USERS_LIMIT=10

# =========================
# Caching
# =========================
BOOK_SEARCH_RESULT_CACHE_TTL=120
TOP_USERS_CACHE_TTL=45
SEARCH_CACHE_NS=v1

# =========================
# Ollama
# =========================
OLLAMA_URL=http://127.0.0.1:11434

# =========================
# TTS / PDF
# =========================
TTS_BACKENDS=edge,espeak
TTS_MAX_INPUT_CHARS=50000
TTS_CHUNK_MAX_CHARS=2200
TTS_CACHE_TTL_S=21600
TTS_CACHE_MAX_ENTRIES=32
TTS_FFMPEG_TIMEOUT_S=120
TTS_VOICE_OPUS_BITRATE=32k
TTS_AUDIO_MP3_QUALITY=4
TTS_AUDIO_FILTERS=
TTS_OLLAMA_MODEL=qwen2.5:7b
TTS_OLLAMA_TIMEOUT=60
PDF_MAKER_OLLAMA_MODEL=qwen2.5:7b
PDF_MAKER_OLLAMA_TIMEOUT=60
BOOK_SUMMARY_OLLAMA_MODEL=qwen2.5:7b
BOOK_SUMMARY_OLLAMA_TIMEOUT=60
BOOK_SUMMARY_OCR_MAX_PAGES=20
BOOK_SUMMARY_MAX_INPUT_CHARS=12000
BOOK_SUMMARY_OCR_DPI=150

# =========================
# Optional Environment Loading
# =========================
# 1 means .env values override existing process env vars.
DOTENV_OVERRIDE=0

# =========================
# Reliability / Logging
# =========================
# 0 keeps pending updates across restarts; 1 drops them.
DROP_PENDING_UPDATES=0
# Rotating error log controls.
ERROR_LOG_MAX_MB=20
ERROR_LOG_BACKUP_COUNT=5
