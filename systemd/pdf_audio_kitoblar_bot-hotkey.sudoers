# Example sudoers drop-in for a local hotkey helper.
# Copy this file and replace `pdfbotadmin` with the account that should run the shortcut.
pdfbotadmin ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
pdfbotadmin ALL=(root) NOPASSWD: /usr/bin/systemctl restart pdf_audio_kitoblar_bot-bot.service
pdfbotadmin ALL=(root) NOPASSWD: /usr/bin/systemctl restart pdf_audio_kitoblar_bot-dashboard.service
